      "Bash(node server.js)",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code}\\\\n\" http://localhost:3000/)",
      "Bash(curl -s http://localhost:3000/)",
      "Bash(curl -s -o /dev/null -w \"styles %{http_code}\\\\n\" http://localhost:3000/styles.css)",
      "Bash(curl -s -o /dev/null -w \"app.js %{http_code}\\\\n\" http://localhost:3000/app.js)",
      "Bash(npm run *)",
      "Bash(curl -s http://localhost:5174/)",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code}\\\\n\" http://localhost:5174/)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000/)",
      "Bash(curl -s http://localhost:3000/styles.css)",
      "Bash(curl -s http://localhost:3000/app.js)",
      "Bash(npm test *)",
