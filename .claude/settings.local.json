      "Bash(curl -s http://localhost:3101/data/explorer/explorer.json -o /dev/null)",
      "Bash(curl -s http://localhost:3101/data/console/console.json -o /dev/null)",
      "Bash(curl -s http://localhost:3101/data/inspector/inspector.json -o /dev/null)",
      "Bash(kill %1)",
      "Bash(pkill -f \"PORT=3101 node server.js\")",
      "Bash(lsof -iTCP:3101 -sTCP:LISTEN)",
      "Bash(kill 5843)"
